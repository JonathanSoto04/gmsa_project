# =============================================================================
#  Gestor Multiservicio de Almacenamiento — plantilla de variables de entorno
#
#  Copia este archivo como .env y rellena los valores reales.
#  Este archivo SÍ puede subirse al repositorio (sin secretos).
# =============================================================================

# -----------------------------------------------------------------------------
#  S3 / MinIO
# -----------------------------------------------------------------------------
MINIO_ENDPOINT=<ip-del-servidor>:9000
MINIO_ACCESS_KEY=<access-key>
MINIO_SECRET_KEY=<secret-key>
MINIO_BUCKET_NAME=<nombre-del-bucket>
MINIO_USE_SSL=False

# -----------------------------------------------------------------------------
#  FTP
# -----------------------------------------------------------------------------
FTP_HOST=<ip-del-servidor>
FTP_PORT=21
FTP_USER=<usuario-ftp>
FTP_PASS=<contraseña-ftp>
FTP_DIR=/

# -----------------------------------------------------------------------------
#  SMB
# -----------------------------------------------------------------------------
SMB_HOST=<ip-del-servidor>
SMB_USER=<usuario-smb>
SMB_PASS=<contraseña-smb>
SMB_SHARE=<nombre-del-share>

# -----------------------------------------------------------------------------
#  NFS (acceso vía SSH — no requiere mount local)
# -----------------------------------------------------------------------------
NFS_HOST=<ip-del-servidor>
NFS_SSH_PORT=22
NFS_USER=<usuario-ssh>
NFS_PASS=<contraseña-ssh>
NFS_DIR=/ruta/al/directorio/nfs
