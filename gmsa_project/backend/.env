# =============================================================================
#  Gestor Multiservicio de Almacenamiento - variables de entorno
#
#  Edita este archivo con los valores reales de tu entorno.
#  NUNCA subas este archivo a un repositorio publico.
# =============================================================================

# -----------------------------------------------------------------------------
#  S3 / MinIO
# -----------------------------------------------------------------------------
MINIO_ENDPOINT=192.168.56.102:9000
MINIO_ACCESS_KEY=minio_admin
MINIO_SECRET_KEY=secret123
MINIO_BUCKET_NAME=storage-s3
MINIO_USE_SSL=False

# -----------------------------------------------------------------------------
#  FTP
# -----------------------------------------------------------------------------
FTP_HOST=192.168.56.102
FTP_PORT=21
FTP_USER=ftpuser
FTP_PASS=secret
FTP_DIR=/

# -----------------------------------------------------------------------------
#  SMB
# -----------------------------------------------------------------------------
SMB_HOST=192.168.56.102
SMB_USER=ftp_user
SMB_PASS=secret
SMB_SHARE=smb
SMB_DIR=/
SMB_DOMAIN=

# -----------------------------------------------------------------------------
#  NFS (acceso via SSH - no requiere mount local)
# -----------------------------------------------------------------------------
NFS_HOST=192.168.56.102
NFS_SSH_PORT=22
NFS_USER=ftpuser
NFS_PASS=secret
NFS_DIR=/mnt/prueba/nfs
